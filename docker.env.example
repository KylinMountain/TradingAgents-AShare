# Docker 部署环境变量配置
# 复制此文件为 .env 并填写配置

# --- 核心模型接入 (必填) ---
TA_API_KEY=your-api-key-here
TA_BASE_URL=https://api.deepseek.com/v1

# 模型配置
TA_LLM_QUICK=deepseek-chat
TA_LLM_DEEP=deepseek-chat

# --- 可选配置 ---
# 提示词语言 (auto / zh / en)
TA_LANGUAGE=zh

# 运行日志追踪 (1 开启 / 0 关闭)
TA_TRACE=1

# 辩论与风险讨论轮数 (1-5)
TA_MAX_DEBATE=1
TA_MAX_RISK=1

# --- 数据库配置 ---
# 默认使用 SQLite，如需 PostgreSQL：
# DATABASE_URL=postgresql://user:password@postgres:5432/tradingagents

# --- CORS 配置 ---
# 如需添加额外允许的域名（逗号分隔）
# CORS_ALLOW_ORIGINS=http://example.com,http://localhost:3000